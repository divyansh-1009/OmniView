<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.omniview.app.ui">

    <!-- Required permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    
    <!-- Required for app detection (REQ-11, REQ-12) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- Required for AccessibilityService integration -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OmniView">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.OmniView">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Settings Activity (REQ-13, REQ-14) -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Settings"
            android:theme="@style/Theme.OmniView" />

        <!-- About Activity -->
        <activity
            android:name=".AboutActivity"
            android:exported="false"
            android:label="About"
            android:theme="@style/Theme.OmniView" />

        <!-- Screenshot Foreground Service -->
        <service
            android:name="com.omniview.app.ingestion.ScreenshotService"
            android:foregroundServiceType="mediaProjection"
            android:exported="false" />

        <!-- AI Engine Foreground Service -->
        <service
            android:name="com.omniview.app.rag.LlamaService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Permission Change Receiver (REQ-2) -->
        <receiver
            android:name="com.omniview.app.ingestion.PermissionMonitor$PermissionChangeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.media.projection.PERMISSION_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- Fires when charger is plugged in (Legacy, kept for compatibility) -->
        <receiver
            android:name="com.omniview.app.intelligence.ChargingReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
            </intent-filter>
        </receiver>

        <!-- Accessibility Service for real-time UI text extraction -->
        <service
            android:name="com.omniview.app.ingestion.ScreenAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>